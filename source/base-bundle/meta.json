{
  "$schema": "/dev/null",
  "metadataVersion": 1,
  "name": "carthing-custom-linux",
  "version": "qn19-product-baseline-2026-06-17",
  "description": "Custom Buildroot Linux userspace for Superbird; P1 FAT boot/state + P2 readonly Buildroot rootfs; GE2D kernel bootfs and baked GE2D/native codec userspace baseline",
  "steps": [
    {
      "type": "bulkcmd",
      "value": "amlmmc key"
    },
    {
      "type": "writeLargeMemory",
      "value": {
        "address": 0,
        "data": {
          "filePath": "bootfs.bin"
        },
        "blockLength": 4096
      }
    },
    {
      "type": "writeLargeMemory",
      "value": {
        "address": 180355072,
        "data": {
          "filePath": "rootfs.img"
        },
        "blockLength": 4096
      }
    },
    {
      "type": "writeEnv",
      "value": {
        "filePath": "env.txt"
      }
    },
    {
      "type": "bulkcmd",
      "value": "saveenv"
    }
  ]
}
