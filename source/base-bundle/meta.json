{
  "$schema": "/dev/null",
  "metadataVersion": 1,
  "name": "carthing-custom-linux",
  "version": "device1-v1-working-2026-05-18",
  "description": "Custom Buildroot Linux userspace for Superbird; persistent HID pairing and AMS runtime proven after cold boot; reuses bootfs/env and replaces only rootfs.img",
  "steps": [
    {
      "type": "bulkcmd",
      "value": "amlmmc key"
    },
    {
      "type": "writeLargeMemory",
      "value": {
        "address": 0,
        "data": {
          "filePath": "bootfs.bin"
        },
        "blockLength": 4096
      }
    },
    {
      "type": "writeLargeMemory",
      "value": {
        "address": 180355072,
        "data": {
          "filePath": "rootfs.img"
        },
        "blockLength": 4096
      }
    },
    {
      "type": "writeEnv",
      "value": {
        "filePath": "env.txt"
      }
    },
    {
      "type": "bulkcmd",
      "value": "saveenv"
    }
  ]
}
