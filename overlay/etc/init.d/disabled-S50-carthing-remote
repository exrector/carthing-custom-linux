#!/bin/sh
set -eu

. /etc/default/carthing

# ВНИМАНИЕ (исправлено 2026-06-10): имя обманчиво — это АКТИВНЫЙ стартер.
# rcS его действительно не матчит (нет префикса S??), но init-wrapper запускает
# его ПО ИМЕНИ на каждом boot. Пока действовал карантин, гейт ниже выходил по
# exit 0; после снятия карантина (решение владельца 2026-06-10) именно этот
# скрипт владеет автостартом runtime (supervisor-петля + pid-файл).
#
# Аварийный рубильник БЕЗ перепрошивки:
#   touch /run/carthing-state/carthing/no-autostart && reboot
if [ "${CARTHING_BUMBLE_QUARANTINE:-1}" != "0" ] || [ "${CARTHING_ALLOW_BUMBLE_RUN:-0}" != "1" ]; then
    echo "[disabled-S50-carthing-remote] Bumble runtime quarantined; not starting"
    exit 0
fi

[ "$CARTHING_AUTOSTART_REMOTE" = "1" ] || exit 0

if [ -f /run/carthing-state/carthing/no-autostart ]; then
    echo "[carthing-remote] autostart disabled by no-autostart flag"
    exit 0
fi

if [ ! -x /usr/libexec/carthing/run-media-remote ]; then
    echo "[S50-carthing-remote] missing runtime launcher"
    exit 1
fi

mkdir -p /run/carthing

if [ -f /run/carthing/media-remote-supervisor.pid ]; then
    old_pid=$(cat /run/carthing/media-remote-supervisor.pid 2>/dev/null || true)
    if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
        echo "[S50-carthing-remote] supervisor already running: $old_pid"
        exit 0
    fi
fi

(
    set +e
    while true; do
        /usr/libexec/carthing/run-media-remote >> "$CARTHING_RUNTIME_LOG" 2>&1
        rc=$?
        echo "[S50-carthing-remote] runtime exited rc=$rc; restarting in 4s" >> "$CARTHING_RUNTIME_LOG"
        sleep 4
    done
) &
echo $! > /run/carthing/media-remote-supervisor.pid

echo "[S50-carthing-remote] supervisor started"
