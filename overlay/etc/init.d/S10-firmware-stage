#!/bin/sh
set -eu

. /etc/default/carthing

mkdir -p "$CARTHING_BT_FIRMWARE_DIR"

need_copy=0
[ -f "$CARTHING_BT_FIRMWARE_DIR/BCM.hcd" ] || need_copy=1
[ -f "$CARTHING_BT_FIRMWARE_DIR/BCM20703A2.hcd" ] || need_copy=1

if [ "$need_copy" -eq 0 ]; then
    echo "[S10-firmware-stage] firmware already present"
    exit 0
fi

if [ ! -d "$CARTHING_BT_SOURCE_FIRMWARE_DIR" ]; then
    echo "[S10-firmware-stage] missing source firmware dir: $CARTHING_BT_SOURCE_FIRMWARE_DIR"
    exit 1
fi

cp "$CARTHING_BT_SOURCE_FIRMWARE_DIR/BCM.hcd" "$CARTHING_BT_FIRMWARE_DIR/BCM.hcd"
cp "$CARTHING_BT_SOURCE_FIRMWARE_DIR/BCM20703A2.hcd" "$CARTHING_BT_FIRMWARE_DIR/BCM20703A2.hcd"

echo "[S10-firmware-stage] firmware staged into $CARTHING_BT_FIRMWARE_DIR"
