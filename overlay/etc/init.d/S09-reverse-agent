#!/bin/sh
set -eu

. /etc/default/carthing

beacon() {
    /usr/libexec/carthing/beacon "$@" || true
}

mark_ip() {
    /usr/libexec/carthing/debug-ip-mark "$@" || true
}

emit_probe_beacon() {
    event=$1
    arg1=${2:-}
    arg2=${3:-}
    arg3=${4:-}

    if [ -n "$arg3" ]; then
        beacon "$event" "$arg1" "$arg2" "$arg3"
    elif [ -n "$arg2" ]; then
        beacon "$event" "$arg1" "$arg2"
    elif [ -n "$arg1" ]; then
        beacon "$event" "$arg1"
    else
        beacon "$event"
    fi
}

emit_probe_beacon_retry() {
    event=$1
    arg1=${2:-}
    arg2=${3:-}
    arg3=${4:-}
    attempt=0

    sleep 2
    while [ "$attempt" -lt 4 ]; do
        emit_probe_beacon "$event" "$arg1" "$arg2" "$arg3"
        attempt=$((attempt + 1))
        [ "$attempt" -lt 4 ] && sleep 2
    done
}

load_probe_state() {
    probe_kind=
    probe_type=
    probe_line=
    probe_msg=
    if [ -f "$1" ]; then
        # File is generated by our own helper and contains only sanitized key=value lines.
        # shellcheck disable=SC1090
        . "$1"
    fi
}

[ "${CARTHING_REVERSE_AGENT_ENABLE:-0}" = "1" ] || exit 0
mark_ip 172.16.42.84

if ! command -v python3 >/dev/null 2>&1; then
    echo "[S09-reverse-agent] python3 not installed"
    mark_ip 172.16.42.184
    beacon s09-no-python
    exit 0
fi

if ! python3 -c 'import json, os, runpy, subprocess, time, urllib.parse, urllib.request, traceback' >/dev/null 2>&1; then
    echo "[S09-reverse-agent] python3 stdlib preflight failed"
    mark_ip 172.16.42.186
    beacon s09-python-preflight-failed
    exit 1
fi

AGENT=/usr/libexec/carthing/reverse-agent.py
PIDFILE=/run/carthing/reverse-agent.pid
LOGFILE=/var/log/reverse-agent.log
PROBE_STATE=/run/carthing/reverse-agent.probe
PROBE_TRACE=/run/carthing/reverse-agent.probe.trace
LATE_REPORT=/run/carthing/s09-late-report
VERSION_FILE=/run/carthing/reverse-agent.version

if [ ! -f "$AGENT" ]; then
    echo "[S09-reverse-agent] missing agent: $AGENT"
    mark_ip 172.16.42.188
    beacon s09-missing-agent
    exit 1
fi

if grep -q '172.16.42.236' "$AGENT" 2>/dev/null; then
    mark_ip 172.16.42.238
else
    mark_ip 172.16.42.239
fi

rm -rf /usr/libexec/carthing/__pycache__ 2>/dev/null || true

mark_ip 172.16.42.224
mkdir -p /run/carthing
rm -f "$PROBE_STATE"
rm -f "$PROBE_TRACE"
rm -f "$LATE_REPORT"
rm -f "$VERSION_FILE"

LOGFILE=/run/carthing/reverse-agent.log
: >>"$LOGFILE"
mark_ip 172.16.42.225

write_late_report() {
    report_event=$1
    report_arg1=${2:-}
    report_arg2=${3:-}
    report_arg3=${4:-}

    {
        printf 'report_event=%s\n' "$report_event"
        printf 'report_arg1=%s\n' "$report_arg1"
        printf 'report_arg2=%s\n' "$report_arg2"
        printf 'report_arg3=%s\n' "$report_arg3"
    } >"$LATE_REPORT"
}

load_probe_signature() {
    probe_type=${probe_type:-}
    probe_line=${probe_line:-}
    probe_msg=${probe_msg:-}

    [ -f "$PROBE_TRACE" ] || return 0

    if [ -z "$probe_type" ] || [ "$probe_type" = "unknown" ]; then
        if grep -q 'SyntaxError' "$PROBE_TRACE"; then
            probe_type=SyntaxError
        elif grep -q 'PyCompileError' "$PROBE_TRACE"; then
            probe_type=PyCompileError
        elif grep -q 'ModuleNotFoundError' "$PROBE_TRACE"; then
            probe_type=ModuleNotFoundError
        elif grep -q 'ImportError' "$PROBE_TRACE"; then
            probe_type=ImportError
        elif grep -q 'NameError' "$PROBE_TRACE"; then
            probe_type=NameError
        elif grep -q 'AttributeError' "$PROBE_TRACE"; then
            probe_type=AttributeError
        elif grep -q 'TypeError' "$PROBE_TRACE"; then
            probe_type=TypeError
        elif grep -q 'ValueError' "$PROBE_TRACE"; then
            probe_type=ValueError
        elif grep -q 'FileNotFoundError' "$PROBE_TRACE"; then
            probe_type=FileNotFoundError
        elif grep -q 'OSError' "$PROBE_TRACE"; then
            probe_type=OSError
        fi
    fi

    if [ -z "${probe_line:-}" ] || [ "$probe_line" = "none" ]; then
        line_text=$(sed -n 's/.*line \([0-9][0-9]*\).*/\1/p' "$PROBE_TRACE" | tail -n 1)
        [ -n "${line_text:-}" ] && probe_line=$line_text
    fi

    if [ -z "${probe_msg:-}" ] || [ "$probe_msg" = "none" ]; then
        msg_text=$(tail -n 1 "$PROBE_TRACE" | tr -cs '[:alnum:]._:-' '_' | sed 's/^_//; s/_$//' | cut -c1-96)
        [ -n "${msg_text:-}" ] && probe_msg=$msg_text
    fi
}

mark_probe_signature_ip() {
    case "${probe_type:-unknown}" in
        PyCompileError|SyntaxError) mark_ip 172.16.42.191 ;;
        ImportError|ModuleNotFoundError) mark_ip 172.16.42.192 ;;
        NameError) mark_ip 172.16.42.193 ;;
        AttributeError) mark_ip 172.16.42.194 ;;
        TypeError) mark_ip 172.16.42.195 ;;
        ValueError) mark_ip 172.16.42.196 ;;
        OSError|FileNotFoundError) mark_ip 172.16.42.197 ;;
        *) mark_ip 172.16.42.198 ;;
    esac
}

mark_ip 172.16.42.226

if AGENT_PATH="$AGENT" PROBE_STATE="$PROBE_STATE" python3 - >"$PROBE_TRACE" 2>&1 <<'PY'
import os
import subprocess
import traceback


def sanitize(value):
    allowed = "._:-"
    output = []
    for ch in str(value):
        if ch.isalnum() or ch in allowed:
            output.append(ch)
        else:
            output.append("_")
    text = "".join(output).strip("_")
    return text[:96] or "empty"


def write_probe(kind, exc):
    probe_path = os.environ["PROBE_STATE"]
    with open(probe_path, "w") as fh:
        fh.write("probe_kind=%s\n" % sanitize(kind))
        fh.write("probe_type=%s\n" % sanitize(exc.__class__.__name__))
        lineno = getattr(exc, "lineno", "")
        fh.write("probe_line=%s\n" % sanitize(lineno))
        fh.write("probe_msg=%s\n" % sanitize(exc))


def mark_specific_ip(exc):
    exc_name = exc.__class__.__name__
    ip_map = {
        "PyCompileError": "172.16.42.191",
        "SyntaxError": "172.16.42.191",
        "ImportError": "172.16.42.192",
        "ModuleNotFoundError": "172.16.42.192",
        "NameError": "172.16.42.193",
        "AttributeError": "172.16.42.194",
        "TypeError": "172.16.42.195",
        "ValueError": "172.16.42.196",
        "OSError": "172.16.42.197",
        "FileNotFoundError": "172.16.42.197",
    }
    ip_address = ip_map.get(exc_name, "172.16.42.198")
    try:
        subprocess.call(
            ["/usr/libexec/carthing/debug-ip-mark", ip_address],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except Exception:
        pass


try:
    with open(os.environ["AGENT_PATH"], "rb") as fh:
        source = fh.read()
    compile(source, os.environ["AGENT_PATH"], "exec")
except BaseException as exc:
    traceback.print_exc()
    write_probe("compile", exc)
    mark_specific_ip(exc)
    raise
PY
then
    cat "$PROBE_TRACE" >>"$LOGFILE" 2>/dev/null || true
else
    cat "$PROBE_TRACE" >>"$LOGFILE" 2>/dev/null || true
    echo "[S09-reverse-agent] compile probe failed"
    load_probe_state "$PROBE_STATE"
    load_probe_signature
    mark_ip 172.16.42.190
    mark_probe_signature_ip
    write_late_report s09-compile-failed "type=${probe_type:-unknown}" "line=${probe_line:-none}" "msg=${probe_msg:-none}"
    emit_probe_beacon_retry s09-compile-failed "type=${probe_type:-unknown}" "line=${probe_line:-none}" "msg=${probe_msg:-none}"
    exit 1
fi
mark_ip 172.16.42.227

if AGENT_PATH="$AGENT" PROBE_STATE="$PROBE_STATE" python3 - >"$PROBE_TRACE" 2>&1 <<'PY'
import os
import runpy
import subprocess
import traceback


def sanitize(value):
    allowed = "._:-"
    output = []
    for ch in str(value):
        if ch.isalnum() or ch in allowed:
            output.append(ch)
        else:
            output.append("_")
    text = "".join(output).strip("_")
    return text[:96] or "empty"


def write_probe(kind, exc):
    probe_path = os.environ["PROBE_STATE"]
    with open(probe_path, "w") as fh:
        fh.write("probe_kind=%s\n" % sanitize(kind))
        fh.write("probe_type=%s\n" % sanitize(exc.__class__.__name__))
        lineno = getattr(exc, "lineno", "")
        fh.write("probe_line=%s\n" % sanitize(lineno))
        fh.write("probe_msg=%s\n" % sanitize(exc))


def mark_specific_ip(exc):
    exc_name = exc.__class__.__name__
    ip_map = {
        "PyCompileError": "172.16.42.191",
        "SyntaxError": "172.16.42.191",
        "ImportError": "172.16.42.192",
        "ModuleNotFoundError": "172.16.42.192",
        "NameError": "172.16.42.193",
        "AttributeError": "172.16.42.194",
        "TypeError": "172.16.42.195",
        "ValueError": "172.16.42.196",
        "OSError": "172.16.42.197",
        "FileNotFoundError": "172.16.42.197",
    }
    ip_address = ip_map.get(exc_name, "172.16.42.198")
    try:
        subprocess.call(
            ["/usr/libexec/carthing/debug-ip-mark", ip_address],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except Exception:
        pass

try:
    runpy.run_path(os.environ["AGENT_PATH"], run_name="__probe__")
except BaseException as exc:
    traceback.print_exc()
    write_probe("runpy", exc)
    mark_specific_ip(exc)
    raise
PY
then
    cat "$PROBE_TRACE" >>"$LOGFILE" 2>/dev/null || true
else
    cat "$PROBE_TRACE" >>"$LOGFILE" 2>/dev/null || true
    echo "[S09-reverse-agent] module probe failed"
    load_probe_state "$PROBE_STATE"
    load_probe_signature
    mark_ip 172.16.42.189
    mark_probe_signature_ip
    write_late_report s09-module-probe-failed "type=${probe_type:-unknown}" "line=${probe_line:-none}" "msg=${probe_msg:-none}"
    emit_probe_beacon_retry s09-module-probe-failed "type=${probe_type:-unknown}" "line=${probe_line:-none}" "msg=${probe_msg:-none}"
    exit 1
fi
mark_ip 172.16.42.228

if [ -f "$PIDFILE" ]; then
    oldpid=$(cat "$PIDFILE" 2>/dev/null || true)
    if [ -n "${oldpid:-}" ] && kill -0 "$oldpid" 2>/dev/null; then
        echo "[S09-reverse-agent] already running pid=$oldpid"
        mark_ip 172.16.42.208
        beacon s09-already-running
        exit 0
    fi
fi

mark_ip 172.16.42.204

(
    exec env PYTHONDONTWRITEBYTECODE=1 python3 -B "$AGENT"
) >>"$LOGFILE" 2>&1 &

echo $! >"$PIDFILE"
mark_ip 172.16.42.205
sleep 1

if kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    echo "[S09-reverse-agent] started pid=$(cat "$PIDFILE")"
    mark_ip 172.16.42.206
    mark_ip 172.16.42.85
    if [ -f "$VERSION_FILE" ]; then
        mark_ip 172.16.42.240
        if grep -q 'py-main-v4' "$VERSION_FILE" 2>/dev/null; then
            mark_ip 172.16.42.241
        fi
    fi
    if [ -s /run/carthing/reverse-agent.state ]; then
        mark_ip 172.16.42.242
    fi
    beacon s09-running
else
    echo "[S09-reverse-agent] exited immediately"
    mark_ip 172.16.42.207
    mark_ip 172.16.42.185
    beacon s09-exited-immediately
fi
