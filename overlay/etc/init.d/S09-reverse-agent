#!/bin/sh
set -eu

. /etc/default/carthing
runtime_env=${CARTHING_DEBUG_RUNTIME_PROFILE:-/run/carthing/debug-runtime.env}
[ -r "$runtime_env" ] && . "$runtime_env"

[ "${CARTHING_REVERSE_AGENT_ENABLE:-0}" = "1" ] || exit 0

if ! command -v python3 >/dev/null 2>&1; then
    echo "[S09-reverse-agent] python3 not installed"
    exit 1
fi

AGENT=/usr/libexec/carthing/reverse-agent.py
PIDFILE=/run/carthing/reverse-agent.pid
LOGFILE=/run/carthing/reverse-agent.log
STATEFILE=/run/carthing/reverse-agent.state

if [ ! -f "$AGENT" ]; then
    echo "[S09-reverse-agent] missing agent: $AGENT"
    exit 1
fi

if [ -f "$PIDFILE" ]; then
    oldpid=$(cat "$PIDFILE" 2>/dev/null || true)
    if [ -n "${oldpid:-}" ] && kill -0 "$oldpid" 2>/dev/null; then
        echo "[S09-reverse-agent] already running pid=$oldpid"
        exit 0
    fi
fi

mkdir -p /run/carthing
rm -f \
    /run/carthing/reverse-agent.probe \
    /run/carthing/reverse-agent.probe.trace \
    /run/carthing/reverse-agent.traceback \
    /run/carthing/reverse-agent.version \
    /run/carthing/s09-late-report

: >>"$LOGFILE"
python3 -B "$AGENT" >"$LOGFILE" 2>&1 &
echo $! >"$PIDFILE"

attempts=3
while [ "$attempts" -gt 0 ]; do
    if kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "running pid=$(cat "$PIDFILE")" >"$STATEFILE"
        echo "[S09-reverse-agent] started pid=$(cat "$PIDFILE")"
        exit 0
    fi
    attempts=$((attempts - 1))
    sleep 1
done

echo "exited-immediately" >"$STATEFILE"
echo "[S09-reverse-agent] exited immediately"
