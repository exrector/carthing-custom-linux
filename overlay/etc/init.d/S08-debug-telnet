#!/bin/sh
set -eu

. /etc/default/carthing
[ -r "${CARTHING_DEBUG_RUNTIME_PROFILE:-/run/carthing/debug-runtime.env}" ] && . "${CARTHING_DEBUG_RUNTIME_PROFILE:-/run/carthing/debug-runtime.env}"

[ "${CARTHING_DEBUG_TELNET_ENABLE:-0}" = "1" ] || exit 0

if ! command -v telnetd >/dev/null 2>&1; then
    echo "[S08-debug-telnet] telnetd not installed"
    exit 0
fi

mkdir -p /run/carthing /var/log

PIDFILE=/run/carthing/debug-telnet.pid
LOGFILE=/run/carthing/debug-telnet.log

if [ -f "$PIDFILE" ]; then
    oldpid=$(cat "$PIDFILE" 2>/dev/null || true)
    if [ -n "${oldpid:-}" ] && kill -0 "$oldpid" 2>/dev/null; then
        echo "[S08-debug-telnet] already running pid=$oldpid"
        exit 0
    fi
fi

: >"$LOGFILE"

(
    exec telnetd -F -p "${CARTHING_DEBUG_TELNET_PORT}" -l /bin/sh
) >"$LOGFILE" 2>&1 &

echo $! >"$PIDFILE"
echo "[S08-debug-telnet] started pid=$(cat "$PIDFILE") port=${CARTHING_DEBUG_TELNET_PORT}"
