#!/bin/sh
set -eu

. /etc/default/carthing

serial=""
bt_mac=""
device_name=""

usid_path=${CARTHING_EFUSE_USID_PATH:-/sys/class/efuse/usid}
if [ -r "$usid_path" ]; then
    full_serial=$(tr -d '\r\n\000' < "$usid_path" 2>/dev/null || true)
    serial=$(printf "%s" "$full_serial" | sed 's/.*\(....\)$/\1/' | tr 'a-z' 'A-Z' || true)
fi

if [ -n "$serial" ]; then
    prefix=${CARTHING_FACTORY_NAME_PREFIX:-Car Thing}
    device_name="${prefix} (SN: ${serial})"
else
    device_name=${CARTHING_DEVICE_NAME:-${CARTHING_BT_ALIAS:-}}
fi

if [ -z "$device_name" ]; then
    base=${CARTHING_NAME_BASE:-CarThing}
    mac=$(printf '%s' "${CARTHING_BD_ADDRESS:-}" | tr -d ':-' | tr 'a-f' 'A-F')
    if [ -n "$mac" ]; then
        device_name="${base}-${mac}"
    else
        device_name="$base"
    fi
fi

if [ -r /sys/class/efuse/mac_bt ]; then
    bt_mac=$(awk -F: '/0x00/ {
        split(toupper($2), s, " ");
        printf("%s:%s:%s:%s:%s:%s\n", s[1], s[2], s[3], s[4], s[5], s[6]);
    }' /sys/class/efuse/mac_bt || true)
fi

printf 'PRETTY_HOSTNAME=%s\n' "$device_name" > /etc/machine-info

if [ -n "$bt_mac" ]; then
    settings_dir="/var/lib/bluetooth/$bt_mac"
    mkdir -p "$settings_dir"
    printf '[General]\nAlias=%s\n' "$device_name" > "$settings_dir/settings"
fi

cat > /etc/superbird <<EOF
{
  "serialNumber": "${serial}",
  "btMac": "${bt_mac}"
}
EOF

echo "[S25-bt-metadata] metadata written"
