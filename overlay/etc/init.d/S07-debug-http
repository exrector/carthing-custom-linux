#!/bin/sh
set -eu

. /etc/default/carthing
[ -r "${CARTHING_DEBUG_RUNTIME_PROFILE:-/run/carthing/debug-runtime.env}" ] && . "${CARTHING_DEBUG_RUNTIME_PROFILE:-/run/carthing/debug-runtime.env}"

[ "${CARTHING_DEBUG_HTTP_ENABLE:-0}" = "1" ] || exit 0

if command -v httpd >/dev/null 2>&1; then
    HTTPD_BIN=httpd
elif command -v busybox >/dev/null 2>&1; then
    HTTPD_BIN="busybox httpd"
else
    echo "[S07-debug-http] no httpd available"
    exit 0
fi

mkdir -p /run/carthing /var/log

PIDFILE=/run/carthing/debug-http.pid
LOGFILE=/run/carthing/debug-http.log

if [ -f "$PIDFILE" ]; then
    oldpid=$(cat "$PIDFILE" 2>/dev/null || true)
    if [ -n "${oldpid:-}" ] && kill -0 "$oldpid" 2>/dev/null; then
        echo "[S07-debug-http] already running pid=$oldpid"
        exit 0
    fi
fi

: >"$LOGFILE"

(
    exec sh -c "exec $HTTPD_BIN -f -p ${CARTHING_DEBUG_HTTP_PORT} -h /"
) >"$LOGFILE" 2>&1 &

echo $! >"$PIDFILE"
echo "[S07-debug-http] started pid=$(cat "$PIDFILE") port=${CARTHING_DEBUG_HTTP_PORT}"
