#!/bin/sh
set -eu

. /etc/default/carthing

state_device=${CARTHING_STATE_DEVICE:-/dev/mmcblk0p1}
state_mount=${CARTHING_STATE_MOUNT:-/run/carthing-state}
keys_file=${CARTHING_RUNTIME_KEYS:-$state_mount/carthing/keys.json}
keys_dir=$(dirname "$keys_file")

mkdir -p "$state_mount"

if ! awk -v target="$state_mount" '$2 == target { found = 1 } END { exit(found ? 0 : 1) }' /proc/mounts; then
    mount -t vfat "$state_device" "$state_mount"
fi

mkdir -p "$keys_dir"

if [ ! -f "$keys_file" ]; then
    printf '{}\n' > "$keys_file"
fi

echo "[S11-runtime-state] state mounted on $state_mount, keys at $keys_file"
