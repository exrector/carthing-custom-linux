#!/bin/sh
set -eu

# Single source of truth for the device name: derive it from the controller MAC
# and set it as the OS hostname, so `ssh root@…` shows which unit this is and
# the BT runtime (BLE + classic) can read it back via socket.gethostname().

[ -f /etc/default/carthing ] && . /etc/default/carthing

base=${CARTHING_NAME_BASE:-CarThing}
mac=$(printf '%s' "${CARTHING_BD_ADDRESS:-}" | tr -d ':-' | tr 'a-f' 'A-F')
if [ -n "$mac" ]; then
    name="${base}-${mac}"
else
    name="$base"
fi

hostname "$name"
printf '%s\n' "$name" > /etc/hostname 2>/dev/null || true
echo "[S04-hostname] hostname=$name"
