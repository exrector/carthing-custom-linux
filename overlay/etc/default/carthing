# Car Thing custom userspace contract

CARTHING_USB_IF=usb0
CARTHING_USB_IP=172.16.42.77
CARTHING_USB_PREFIX=24
CARTHING_USB_ENABLE_DHCP=0

CARTHING_BT_UART=/dev/ttyS1
CARTHING_BT_RESET_GPIO=493
CARTHING_BT_FIRMWARE_DIR=/lib/firmware/brcm
CARTHING_BT_SOURCE_FIRMWARE_DIR=/usr/share/carthing/firmware/brcm
CARTHING_BT_RUNTIME_FIRMWARE_DIR=/run/carthing/firmware/brcm
CARTHING_BT_FIRMWARE=/lib/firmware/brcm/BCM4345C0.hcd
CARTHING_BT_INIT_BACKEND=attach
CARTHING_BT_FWLOAD_BINARY=/usr/bin/carthing-bt-fwload
CARTHING_BT_FWLOAD_LOG=/run/carthing-bt-fwload.log
CARTHING_BT_DOWNLOAD_BAUD=115200
CARTHING_BT_CONTROLLER_BAUD=3000000
CARTHING_BT_FWLOAD_ARGS=
CARTHING_BT_ATTACH_BINARY=/usr/bin/carthing-btattach-mini
CARTHING_BT_ATTACH_LOG=/run/carthing-btattach.log
CARTHING_BT_ATTACH_PIDFILE=/run/carthing-btattach.pid
CARTHING_BT_ATTACH_BAUD=115200
CARTHING_BT_ATTACH_ARGS=
CARTHING_BT_BUMBLE_TRANSPORT=hci-socket:0
CARTHING_BT_ALIAS="Car Thing"

CARTHING_STATE_DEVICE=/dev/mmcblk0p1
CARTHING_STATE_MOUNT=/run/carthing-state

CARTHING_RUNTIME_ROOT=/usr/lib/carthing
CARTHING_RUNTIME_ENTRY=/usr/lib/carthing/carthing_runtime.py
CARTHING_RUNTIME_LIB=/usr/lib/carthing/vendor
CARTHING_RUNTIME_KEYS=/run/carthing-state/carthing/keys.json
CARTHING_RUNTIME_LOG=/run/carthing/carthing-remote.log
CARTHING_AUTOSTART_REMOTE=1
# Bumble quarantine is the deliberate release-state while the Bluetooth base
# layer is being redesigned. Keep the old Python/Bumble runtime on disk for
# reference, but do not allow boot scripts or local tools to start it by
# accident. A manual lab run must set both:
#   CARTHING_BUMBLE_QUARANTINE=0
#   CARTHING_ALLOW_BUMBLE_RUN=1
CARTHING_BUMBLE_QUARANTINE=1
CARTHING_ALLOW_BUMBLE_RUN=0
CARTHING_BD_ADDRESS=30:E3:D6:00:5F:A4
CARTHING_FONT_PATH=/usr/share/fonts/truetype/DejaVuSans.ttf
# One name everywhere comes from manufacturing efuse USID when available.
CARTHING_FACTORY_NAME_PREFIX="Car Thing"
CARTHING_NAME_BASE=CarThing
# Keep the transfer/A2DP surface off by default. Enabling it at boot exposes a
# second classic-audio identity next to the BLE media remote on iOS/macOS.
CARTHING_A2DP_BRIDGE_ENABLE=0
CARTHING_A2DP_AUTOCONNECT=0
CARTHING_TRUSTED_DEVICES=/run/carthing-state/carthing/trusted-devices.json

CARTHING_SSH_ENABLE=1
CARTHING_DROPBEAR_ARGS=""
CARTHING_DEBUG_HTTP_ENABLE=1
CARTHING_DEBUG_HTTP_PORT=8080
CARTHING_DEBUG_TELNET_ENABLE=1
CARTHING_DEBUG_TELNET_PORT=2323
CARTHING_DEBUG_BEACON_ENABLE=0
CARTHING_DEBUG_BEACON_URL=http://172.16.42.1:8099
CARTHING_DEBUG_IP_MARK_ENABLE=0

CARTHING_REVERSE_AGENT_ENABLE=1
CARTHING_REVERSE_AGENT_URL=http://172.16.42.1:8099
CARTHING_REVERSE_AGENT_DEVICE_ID=device1
CARTHING_REVERSE_AGENT_POLL_INTERVAL=2
CARTHING_REVERSE_AGENT_COMMAND_TIMEOUT=45
CARTHING_REVERSE_AGENT_MAX_OUTPUT=65536
