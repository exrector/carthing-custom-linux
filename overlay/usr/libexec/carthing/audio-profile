#!/bin/sh
set -eu

[ -r /etc/default/carthing ] && . /etc/default/carthing

profile_file=${CARTHING_AUDIO_PROFILE_FILE:-/run/carthing/audio-profile}
runtime_file=${CARTHING_AUDIO_RUNTIME_PROFILE:-/run/carthing/audio-runtime.env}

usage() {
    echo "usage: audio-profile get|set <profile>|apply|list|status" >&2
    exit 2
}

ensure_dirs() {
    mkdir -p "$(dirname "$profile_file")" "$(dirname "$runtime_file")"
}

write_runtime() {
    ensure_dirs
    profile=$1
    case "$profile" in
        off)
            cat >"$runtime_file" <<'EOF'
CARTHING_AUDIO_PLAYBACK=0
CARTHING_AUDIO_CAPTURE=0
CARTHING_AUDIO_BRIDGE=0
EOF
            ;;
        playback)
            cat >"$runtime_file" <<'EOF'
CARTHING_AUDIO_PLAYBACK=1
CARTHING_AUDIO_CAPTURE=0
CARTHING_AUDIO_BRIDGE=0
EOF
            ;;
        capture)
            cat >"$runtime_file" <<'EOF'
CARTHING_AUDIO_PLAYBACK=0
CARTHING_AUDIO_CAPTURE=1
CARTHING_AUDIO_BRIDGE=0
EOF
            ;;
        bridge)
            cat >"$runtime_file" <<'EOF'
CARTHING_AUDIO_PLAYBACK=1
CARTHING_AUDIO_CAPTURE=0
CARTHING_AUDIO_BRIDGE=1
EOF
            ;;
        full)
            cat >"$runtime_file" <<'EOF'
CARTHING_AUDIO_PLAYBACK=1
CARTHING_AUDIO_CAPTURE=1
CARTHING_AUDIO_BRIDGE=1
EOF
            ;;
        *)
            echo "unsupported audio profile: $profile" >&2
            exit 1
            ;;
    esac
}

current_profile() {
    if [ -r "$profile_file" ]; then
        head -n 1 "$profile_file"
    else
        echo "${CARTHING_AUDIO_PROFILE:-playback}"
    fi
}

case "${1:-}" in
    get)
        current_profile
        ;;
    set)
        [ $# -eq 2 ] || usage
        ensure_dirs
        printf '%s\n' "$2" >"$profile_file"
        write_runtime "$2"
        ;;
    apply)
        profile="${2:-$(current_profile)}"
        write_runtime "$profile"
        ;;
    list)
        cat <<'EOF'
off
playback
capture
bridge
full
EOF
        ;;
    status)
        echo "profile=$(current_profile)"
        [ -r "$runtime_file" ] && cat "$runtime_file"
        ;;
    *)
        usage
        ;;
esac
