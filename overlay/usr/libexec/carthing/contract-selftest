#!/bin/sh
set -eu

. /etc/default/carthing

check_path() {
    path="$1"
    if [ -e "$path" ]; then
        echo "[ok] $path"
    else
        echo "[missing] $path"
        failed=1
    fi
}

check_cmd() {
    name="$1"
    if command -v "$name" >/dev/null 2>&1; then
        echo "[ok] command $name"
    else
        echo "[missing] command $name"
        failed=1
    fi
}

failed=0

check_path /bin/init
check_path "$CARTHING_BT_UART"
check_path /dev/dri/card0
check_path /sys/class/gpio
check_path /sys/class/efuse
check_path /dev/input
check_path "$CARTHING_BT_FIRMWARE_DIR/BCM.hcd"
check_path "$CARTHING_BT_FIRMWARE_DIR/BCM20703A2.hcd"
check_path "$CARTHING_BT_FIRMWARE_DIR/BCM4345C0.hcd"
check_path "$CARTHING_RUNTIME_ENTRY"
check_path "$CARTHING_RUNTIME_LIB/BUMBLE-VERSION"
check_path "$CARTHING_RUNTIME_LIB/bumble/_version.py"
check_path "$CARTHING_RUNTIME_LIB/bumble/pairing.py"
check_path "$CARTHING_RUNTIME_LIB/bumble/host.py"
check_path "$CARTHING_RUNTIME_LIB/bumble/transport/hci_socket.py"
check_path "$CARTHING_FONT_PATH"
check_path "$CARTHING_STATE_DEVICE"
check_path /root/.ssh/authorized_keys
check_path /etc/shadow

check_cmd sh
check_cmd ip
check_cmd awk
check_cmd sed
check_cmd python3
check_cmd dropbear
check_cmd dropbearkey

if /usr/libexec/carthing/python-runtime-selftest; then
    echo "[ok] full Python application runtime"
else
    echo "[missing] full Python application runtime"
    failed=1
fi

if [ "${CARTHING_DEBUG_HTTP_ENABLE:-0}" = "1" ]; then
    if command -v httpd >/dev/null 2>&1 || command -v busybox >/dev/null 2>&1; then
        echo "[ok] debug httpd available"
    else
        echo "[missing] debug httpd"
        failed=1
    fi
fi

if [ "${CARTHING_DEBUG_TELNET_ENABLE:-0}" = "1" ]; then
    check_cmd telnetd
fi

if [ "$CARTHING_BT_INIT_BACKEND" = "fwload" ]; then
    check_path "$CARTHING_BT_FWLOAD_BINARY"
fi

if [ "$CARTHING_BT_INIT_BACKEND" = "attach" ]; then
    check_path "$CARTHING_BT_ATTACH_BINARY"
    check_path /sys/module/hci_uart
fi

if [ "$failed" -ne 0 ]; then
    exit 1
fi
