#!/bin/sh
set -u

export PATH=/usr/libexec/carthing:/usr/sbin:/usr/bin:/sbin:/bin

LOG_DIR=/run/carthing
LOG_FILE="$LOG_DIR/init-wrapper.log"
S09_LATE_REPORT="$LOG_DIR/s09-late-report"
STAGE2_ONCE_MARK="$LOG_DIR/init-wrapper-done"

ensure_early_mounts() {
    mkdir -p /proc /sys /dev /dev/pts /run /tmp /var/log /etc/dropbear /root/.ssh 2>/dev/null || true

    mount -t devtmpfs devtmpfs /dev 2>/dev/null || true
    mount -t proc proc /proc 2>/dev/null || true
    mount -t sysfs sysfs /sys 2>/dev/null || true
    mount -t devpts devpts /dev/pts 2>/dev/null || true
    mount -t tmpfs -o mode=0755,nodev,nosuid tmpfs /run 2>/dev/null || true

    mkdir -p "$LOG_DIR" 2>/dev/null || true
}

ensure_early_mounts

log() {
    msg="[init-wrapper] $*"
    echo "$msg" >>"$LOG_FILE" 2>/dev/null || true
    echo "$msg" >/dev/kmsg 2>/dev/null || true
}

mark_ip() {
    /usr/libexec/carthing/debug-ip-mark "$@" || true
}

log "stage-2 entry"
/usr/libexec/carthing/beacon init-wrapper-entry || true

emit_late_service_reports() {
    report_event=
    report_arg1=
    report_arg2=
    report_arg3=

    if [ -f "$S09_LATE_REPORT" ]; then
        # File is generated by our own init scripts and contains simple key=value lines.
        # shellcheck disable=SC1090
        . "$S09_LATE_REPORT"
        if [ -n "${report_event:-}" ]; then
            if [ -n "${report_arg3:-}" ]; then
                /usr/libexec/carthing/beacon "$report_event" "$report_arg1" "$report_arg2" "$report_arg3" || true
            elif [ -n "${report_arg2:-}" ]; then
                /usr/libexec/carthing/beacon "$report_event" "$report_arg1" "$report_arg2" || true
            elif [ -n "${report_arg1:-}" ]; then
                /usr/libexec/carthing/beacon "$report_event" "$report_arg1" || true
            else
                /usr/libexec/carthing/beacon "$report_event" || true
            fi
        fi
    fi
}

if [ -x /etc/init.d/S05-usbnet ]; then
    log "running early S05-usbnet"
    mark_ip 172.16.42.210
    /etc/init.d/S05-usbnet >>"$LOG_FILE" 2>&1 || log "S05-usbnet failed: $?"
    mark_ip 172.16.42.211
else
    log "missing /etc/init.d/S05-usbnet"
fi

if [ -x /etc/init.d/S06-ssh ]; then
    log "running early S06-ssh"
    mark_ip 172.16.42.212
    /etc/init.d/S06-ssh >>"$LOG_FILE" 2>&1 || log "S06-ssh failed: $?"
    mark_ip 172.16.42.213
else
    log "missing /etc/init.d/S06-ssh"
fi

if [ -x /etc/init.d/S07-debug-http ]; then
    log "running early S07-debug-http"
    /etc/init.d/S07-debug-http >>"$LOG_FILE" 2>&1 || log "S07-debug-http failed: $?"
else
    log "missing /etc/init.d/S07-debug-http"
fi

if [ -x /etc/init.d/S08-debug-telnet ]; then
    log "running early S08-debug-telnet"
    /etc/init.d/S08-debug-telnet >>"$LOG_FILE" 2>&1 || log "S08-debug-telnet failed: $?"
else
    log "missing /etc/init.d/S08-debug-telnet"
fi

if [ -x /etc/init.d/S09-reverse-agent ]; then
    log "running early S09-reverse-agent"
    mark_ip 172.16.42.214
    /etc/init.d/S09-reverse-agent >>"$LOG_FILE" 2>&1 || log "S09-reverse-agent failed: $?"
    mark_ip 172.16.42.215
else
    log "missing /etc/init.d/S09-reverse-agent"
fi

emit_late_service_reports
/usr/libexec/carthing/beacon init-wrapper-services-done || true
mark_ip 172.16.42.216
: >"$STAGE2_ONCE_MARK"

log "execing busybox init"
exec /bin/busybox init
