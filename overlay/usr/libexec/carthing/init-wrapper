#!/bin/sh
set -u

export PATH=/usr/libexec/carthing:/usr/sbin:/usr/bin:/sbin:/bin

LOG_DIR=/run/carthing
LOG_FILE="$LOG_DIR/init-wrapper.log"
STAGE2_ONCE_MARK="$LOG_DIR/init-wrapper-done"

ensure_early_mounts() {
    mkdir -p /proc /sys /dev /dev/pts /run /tmp /var/log /etc/dropbear /root/.ssh 2>/dev/null || true

    mount -t devtmpfs devtmpfs /dev 2>/dev/null || true
    mount -t proc proc /proc 2>/dev/null || true
    mount -t sysfs sysfs /sys 2>/dev/null || true
    mount -t devpts devpts /dev/pts 2>/dev/null || true
    mount -t tmpfs -o mode=0755,nodev,nosuid tmpfs /run 2>/dev/null || true

    mkdir -p "$LOG_DIR" 2>/dev/null || true
}

log() {
    msg="[init-wrapper] $*"
    echo "$msg" >>"$LOG_FILE" 2>/dev/null || true
    echo "$msg" >/dev/kmsg 2>/dev/null || true
}

run_early_service() {
    script=$1
    name=${script##*/}

    if [ ! -x "$script" ]; then
        log "missing $script"
        return 0
    fi

    log "running early $name"
    if "$script" >>"$LOG_FILE" 2>&1; then
        :
    else
        status=$?
        log "$name failed: $status"
    fi
}

ensure_early_mounts

log "stage-2 entry"

run_early_service /etc/init.d/S05-usbnet
run_early_service /etc/init.d/S06-ssh
run_early_service /etc/init.d/S07-debug-http
run_early_service /etc/init.d/S08-debug-telnet
run_early_service /etc/init.d/S09-reverse-agent
run_early_service /etc/init.d/S10-firmware-stage
run_early_service /etc/init.d/S20-bt-init
run_early_service /etc/init.d/S45-input-links
run_early_service /etc/init.d/S50-carthing-remote

: >"$STAGE2_ONCE_MARK"

log "execing busybox init"
exec /bin/busybox init
