#!/bin/sh
set -u

export PATH=/usr/libexec/carthing:/usr/sbin:/usr/bin:/sbin:/bin

LOG_DIR=/run/carthing
LOG_FILE="$LOG_DIR/init-wrapper.log"
CARTHING_USB_IF=${CARTHING_USB_IF:-usb0}
CARTHING_USB_IP=${CARTHING_USB_IP:-172.16.42.77}
CARTHING_USB_PREFIX=${CARTHING_USB_PREFIX:-24}
CARTHING_DEBUG_TELNET_ENABLE=${CARTHING_DEBUG_TELNET_ENABLE:-1}
CARTHING_DEBUG_TELNET_PORT=${CARTHING_DEBUG_TELNET_PORT:-2323}

if [ -r /etc/default/carthing ]; then
    # shellcheck disable=SC1091
    . /etc/default/carthing
fi

ensure_early_mounts() {
    mkdir -p /proc /sys /dev /dev/pts /run /tmp /var/log /etc/dropbear /root/.ssh 2>/dev/null || true

    mount -t devtmpfs devtmpfs /dev 2>/dev/null || true
    mount -t proc proc /proc 2>/dev/null || true
    mount -t sysfs sysfs /sys 2>/dev/null || true
    mount -t devpts devpts /dev/pts 2>/dev/null || true
    mount -t tmpfs -o mode=0755,nodev,nosuid tmpfs /run 2>/dev/null || true

    mkdir -p "$LOG_DIR" 2>/dev/null || true
}

ensure_early_mounts

log() {
    msg="[init-wrapper] $*"
    echo "$msg" >>"$LOG_FILE" 2>/dev/null || true
    echo "$msg" >/dev/kmsg 2>/dev/null || true
}

log "stage-2 entry"
/usr/libexec/carthing/beacon init-wrapper-entry || true

list_early_usb_candidates() {
    if [ -n "${CARTHING_USB_IF:-}" ] && [ -d "/sys/class/net/$CARTHING_USB_IF" ]; then
        echo "$CARTHING_USB_IF"
    fi

    for netdir in /sys/class/net/*; do
        [ -e "$netdir" ] || continue
        name=${netdir##*/}
        [ "$name" = "lo" ] && continue
        [ "$name" = "${CARTHING_USB_IF:-}" ] && continue
        case "$name" in
            usb*|eth*|en*|ncm*|rndis*)
                echo "$name"
                ;;
        esac
    done

    if [ -r /proc/net/dev ]; then
        sed -n '3,$p' /proc/net/dev | while IFS=: read -r raw_name _; do
            name=$(echo "$raw_name" | tr -d '[:space:]')
            [ -n "$name" ] || continue
            [ "$name" = "lo" ] && continue
            [ "$name" = "${CARTHING_USB_IF:-}" ] && continue
            case "$name" in
                usb*|eth*|en*|ncm*|rndis*)
                    echo "$name"
                    ;;
            esac
        done
    fi
}

early_configure_iface() {
    iface=$1

    if command -v ifconfig >/dev/null 2>&1; then
        ifconfig "$iface" "${CARTHING_USB_IP}" netmask 255.255.255.0 up 2>/dev/null \
            || ifconfig "$iface" up "${CARTHING_USB_IP}" netmask 255.255.255.0 2>/dev/null \
            || true
    fi

    if command -v ip >/dev/null 2>&1; then
        ip link set "$iface" up 2>/dev/null || true
        ip addr flush dev "$iface" 2>/dev/null || true
        ip addr add "${CARTHING_USB_IP}/${CARTHING_USB_PREFIX}" dev "$iface" 2>/dev/null || true
    fi

    printf '%s\n' "$iface" >/run/carthing/early-usb-iface 2>/dev/null || true
}

early_usb_bootstrap() {
    configured=
    for iface in $(list_early_usb_candidates); do
        early_configure_iface "$iface"
        configured="${configured}${configured:+ }$iface"
    done

    if [ -n "$configured" ]; then
        log "early usb configured: $configured -> ${CARTHING_USB_IP}/${CARTHING_USB_PREFIX}"
        /usr/libexec/carthing/beacon init-wrapper-early-usb "$configured" || true
        return 0
    fi

    log "early usb: no candidate iface yet"
    return 1
}

start_early_telnet() {
    [ "${CARTHING_DEBUG_TELNET_ENABLE:-0}" = "1" ] || return 0
    command -v telnetd >/dev/null 2>&1 || return 0

    if command -v pidof >/dev/null 2>&1 && pidof telnetd >/dev/null 2>&1; then
        return 0
    fi

    (
        exec telnetd -F -p "${CARTHING_DEBUG_TELNET_PORT}" -l /bin/sh
    ) >/var/log/early-telnet.log 2>&1 &

    sleep 1
    if kill -0 "$!" 2>/dev/null; then
        echo "$!" >/run/carthing/early-telnet.pid 2>/dev/null || true
        log "early telnet started on ${CARTHING_DEBUG_TELNET_PORT}"
        /usr/libexec/carthing/beacon init-wrapper-early-telnet "${CARTHING_DEBUG_TELNET_PORT}" || true
    else
        log "early telnet exited immediately"
    fi
}

early_usb_bootstrap || true
start_early_telnet || true

if [ -x /etc/init.d/S05-usbnet ]; then
    log "running early S05-usbnet"
    /etc/init.d/S05-usbnet >>"$LOG_FILE" 2>&1 || log "S05-usbnet failed: $?"
else
    log "missing /etc/init.d/S05-usbnet"
fi

if [ -x /etc/init.d/S06-ssh ]; then
    log "running early S06-ssh"
    /etc/init.d/S06-ssh >>"$LOG_FILE" 2>&1 || log "S06-ssh failed: $?"
else
    log "missing /etc/init.d/S06-ssh"
fi

if [ -x /etc/init.d/S07-debug-http ]; then
    log "running early S07-debug-http"
    /etc/init.d/S07-debug-http >>"$LOG_FILE" 2>&1 || log "S07-debug-http failed: $?"
else
    log "missing /etc/init.d/S07-debug-http"
fi

if [ -x /etc/init.d/S08-debug-telnet ]; then
    log "running early S08-debug-telnet"
    /etc/init.d/S08-debug-telnet >>"$LOG_FILE" 2>&1 || log "S08-debug-telnet failed: $?"
else
    log "missing /etc/init.d/S08-debug-telnet"
fi

if [ -x /etc/init.d/S09-reverse-agent ]; then
    log "running early S09-reverse-agent"
    /etc/init.d/S09-reverse-agent >>"$LOG_FILE" 2>&1 || log "S09-reverse-agent failed: $?"
else
    log "missing /etc/init.d/S09-reverse-agent"
fi

/usr/libexec/carthing/beacon init-wrapper-services-done || true

(
    tries=18
    while [ "$tries" -gt 0 ]; do
        tries=$((tries - 1))
        sleep 5
        early_usb_bootstrap || true
        start_early_telnet || true
        /etc/init.d/S05-usbnet >>"$LOG_FILE" 2>&1 || true
        /etc/init.d/S06-ssh >>"$LOG_FILE" 2>&1 || true
        /etc/init.d/S07-debug-http >>"$LOG_FILE" 2>&1 || true
        /etc/init.d/S08-debug-telnet >>"$LOG_FILE" 2>&1 || true
        /etc/init.d/S09-reverse-agent >>"$LOG_FILE" 2>&1 || true
    done
) >/dev/null 2>&1 &

log "execing busybox init"
exec /bin/busybox init
