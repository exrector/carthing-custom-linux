#!/bin/sh
set -eu

. /etc/default/carthing

# Last-resort guard. The init script is disabled as well, but this launcher can
# still be run by hand or by an old handoff note. Refuse unless the lab override
# is explicit.
if [ "${CARTHING_BUMBLE_QUARANTINE:-1}" != "0" ] || [ "${CARTHING_ALLOW_BUMBLE_RUN:-0}" != "1" ]; then
    echo "[run-media-remote] Bumble runtime quarantined; set CARTHING_BUMBLE_QUARANTINE=0 CARTHING_ALLOW_BUMBLE_RUN=1 for a manual lab run"
    exit 0
fi

export PYTHONPATH="$CARTHING_RUNTIME_LIB"
export CAR_THING_LIB="$CARTHING_RUNTIME_LIB"
export CAR_THING_KEYSTORE="$CARTHING_RUNTIME_KEYS"

transport=${CARTHING_BT_BUMBLE_TRANSPORT:-}
if [ -z "$transport" ]; then
    case "${CARTHING_BT_INIT_BACKEND:-fwload}" in
        attach)
            transport=hci-socket:0
            ;;
        *)
            transport="serial:${CARTHING_BT_UART},${CARTHING_BT_CONTROLLER_BAUD:-3000000}"
            ;;
    esac
fi

export CAR_THING_TRANSPORT="$transport"
export CAR_THING_BD_ADDRESS="$CARTHING_BD_ADDRESS"
export CARTHING_BT_ALIAS="${CARTHING_BT_ALIAS:-}"
export CARTHING_DEVICE_NAME="${CARTHING_DEVICE_NAME:-${CARTHING_BT_ALIAS:-}}"
export CARTHING_FACTORY_NAME_PREFIX="${CARTHING_FACTORY_NAME_PREFIX:-Car Thing}"
export CARTHING_EFUSE_USID_PATH="${CARTHING_EFUSE_USID_PATH:-/sys/class/efuse/usid}"
export CARTHING_NAME_BASE="${CARTHING_NAME_BASE:-CarThing}"
export CARTHING_A2DP_BRIDGE_ENABLE="${CARTHING_A2DP_BRIDGE_ENABLE:-0}"
export CARTHING_A2DP_AUTOCONNECT="${CARTHING_A2DP_AUTOCONNECT:-0}"
export CARTHING_TRUSTED_DEVICES="${CARTHING_TRUSTED_DEVICES:-/run/carthing-state/carthing/trusted-devices.json}"
export CARTHING_INPUT_BUTTONS=/run/carthing/input-buttons
export CARTHING_INPUT_ROTARY=/run/carthing/input-rotary

if [ ! -f "$CARTHING_RUNTIME_ENTRY" ]; then
    echo "[run-media-remote] missing runtime entry: $CARTHING_RUNTIME_ENTRY"
    exit 1
fi

exec python3 "$CARTHING_RUNTIME_ENTRY"
