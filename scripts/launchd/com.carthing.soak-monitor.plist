<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.carthing.soak-monitor</string>
    <key>ProgramArguments</key>
    <array>
        <string>__PYTHON__</string>
        <string>__MONITOR__</string>
        <string>--interval</string>
        <string>10</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>
    <key>ProcessType</key>
    <string>Background</string>
    <key>StandardOutPath</key>
    <string>__LOG_DIR__/soak-monitor.out.log</string>
    <key>StandardErrorPath</key>
    <string>__LOG_DIR__/soak-monitor.err.log</string>
</dict>
</plist>
