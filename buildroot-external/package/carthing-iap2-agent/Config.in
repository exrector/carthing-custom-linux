config BR2_PACKAGE_CARTHING_IAP2_AGENT
	bool "carthing-iap2-agent"
	depends on BR2_PACKAGE_GLIB2
	depends on BR2_PACKAGE_DBUS
	depends on BR2_PACKAGE_BLUEZ5_UTILS
	help
	  Legacy Apple-oriented iAP2/MFi agent path for Car Thing.

	  This is a separate architecture track from the current
	  Bumble/HID/AMS runtime. It requires BlueZ, D-Bus and the
	  inherited apple_mfi kernel/device path.
